# Required Grafana config
GRAFANA_URL="https://grafana.example.com"
GRAFANA_API_TOKEN=""
GRAFANA_ORG_ID=""

# MCP transport config
MCP_TRANSPORTS="stdio,http"
MCP_HTTP_HOST="0.0.0.0"
MCP_HTTP_PORT="8080"
MCP_HTTP_BEARER_TOKEN=""

# Guardrails
GRAFANA_DATASOURCE_ALLOWLIST="prometheus-main,prometheus-readonly"
GRAFANA_QUERY_TIMEOUT_MS="10000"
GRAFANA_MAX_POINTS="2000"
MCP_MAX_RESPONSE_BYTES="200000"
